# =================================================================
# AGNO SUPERPOWERS TEAM - CONFIGURATION
# =================================================================

# --- AI MODEL (REQUIRED) ---
# Your OpenAI API Key for GPT-4o
OPENAI_API_KEY=ollama
OPENAI_MODEL=gemma4:e2b
OPENAI_BASE_URL=http://localhost:11434/v1

# --- MCP: GITHUB (OPTIONAL) ---
# A Fine-Grained Personal Access Token (PAT) increases API limits.
# Create a token with "Read-only" access to public repositories.
# If left empty, the team will use 'git clone' via Shell as fallback.
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- MCP: CONTEXT7 (UPSTASH) ---
# This MCP server is loaded via npx and currently requires no key.
# Here you can set default values for token processing.
DEFAULT_MINIMUM_TOKENS=1000

# --- PROJECT SETTINGS ---
# Name of the project (often used for logs or DB names)
PROJECT_NAME=superpowers-dev-system

# SQLite database location in container
# The file will automatically appear in your local ./output folder
DATABASE_URL=sqlite:////app/workspace/project_database.db

# --- AGNO / DEBUGGING ---
# Set to DEBUG to see detailed logs of agent interactions
AGNO_LOG_LEVEL=INFO
SHOW_TOOL_CALLS=true